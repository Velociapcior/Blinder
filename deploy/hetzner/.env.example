# Domain
DOMAIN=blinder.app
ACME_EMAIL=admin@blinder.app

# Database
POSTGRES_DB=blinder
POSTGRES_HOST_PORT=5432
POSTGRES_ADMIN_USER=blinder_admin
POSTGRES_ADMIN_PASSWORD=<strong-random-password>
IDENTITY_DB_USER=blinder_identity
IDENTITY_DB_PASSWORD=<strong-random-password>
API_DB_USER=blinder_api
API_DB_PASSWORD=<strong-random-password>

# MinIO
MINIO_ACCESS_KEY=<minio-access-key>
MINIO_SECRET_KEY=<minio-secret-key-min-16-chars>

# Identity key material
IDENTITY_KEYS_PASSWORD=<identity-key-password>

# Container registry
REGISTRY=ghcr.io/your-org
IMAGE_TAG=latest
