# Local baseline defaults for the root Docker Compose stack.
# Copy to .env if you want to override them locally.

DOMAIN=blinder.local
POSTGRES_DB=blinder
POSTGRES_HOST_PORT=5432
POSTGRES_ADMIN_USER=blinder_admin
POSTGRES_ADMIN_PASSWORD=blinder_admin_dev_password
IDENTITY_DB_USER=blinder_identity
IDENTITY_DB_PASSWORD=blinder_identity_dev_password
API_DB_USER=blinder_api
API_DB_PASSWORD=blinder_api_dev_password
MINIO_ACCESS_KEY=blinderminio
MINIO_SECRET_KEY=blinderminiosecret
IDENTITY_KEYS_PASSWORD=blinder-local-identity-password
