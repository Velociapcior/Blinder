# .env.example — committed to source control.
# Copy to .env and fill real values. NEVER commit .env.
#
# WARNING: docker compose down -v DESTROYS db-data volume and ALL persisted data.
#          In production always use: docker compose down  (without -v)
#          See project-context.md rule 13.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=blinder
POSTGRES_USER=blinder
POSTGRES_PASSWORD=change_me_in_production

# ── Identity Server (Blinder.IdentityServer — OAuth2/OIDC, Story 2-0) ────────
# RSA-256 certificates for token signing and encryption (production only).
# Development uses AddDevelopmentSigningCertificate() / AddDevelopmentEncryptionCertificate() — no certs needed.
# Generate with: openssl req -x509 -newkey rsa:4096 -keyout key.pem -out cert.pem -days 3650 -nodes
# Then base64-encode: base64 -w 0 cert.pfx
AUTH_SIGNING_CERT_BASE64=      # RSA-256 signing cert, base64-encoded PFX (production)
AUTH_SIGNING_CERT_PASSWORD=    # PFX password (production)
AUTH_ENCRYPTION_CERT_BASE64=   # RSA-256 encryption cert, base64-encoded PFX (production)
AUTH_ENCRYPTION_CERT_PASSWORD= # PFX password (production)

# ── Object Storage (Hetzner / S3-compatible) ─────────────────────────────────
S3_ENDPOINT=https://your-bucket.your-region.your-provider.com
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET_NAME=blinder-photos
# Note: ForcePathStyle=true is required for Hetzner Object Storage (ARCH-17)

# ── Push Notifications ────────────────────────────────────────────────────────
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project-id"}
APNS_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
APNS_KEY_ID=your-key-id
APNS_TEAM_ID=your-team-id
APNS_BUNDLE_ID=com.yourcompany.blinder

# ── Mobile ────────────────────────────────────────────────────────────────────
# Android emulator: use 10.0.2.2 (host machine). iOS simulator: use localhost.
EXPO_PUBLIC_API_URL=http://10.0.2.2/api
