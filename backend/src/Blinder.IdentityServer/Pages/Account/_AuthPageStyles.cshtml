<style>
@@import url("https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700;900&display=swap");

:root {
    --bg-base: #FBF5EE;
    --bg-surface: #EDE3D8;
    --bg-elevated: #F5EDE2;
    --bg-dark: #2C1C1A;

    --primary: #8B4E6E;
    --primary-light: #B87A98;
    --accent: #C4825A;

    --text-primary: #2C1C1A;
    --text-secondary: #7A5A52;
    --text-muted: #A08878;

    --border: #DDD0C4;
    --error: #B85050;

    --on-primary: #FFFFFF;

    --font-sans: "Lato", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;

    --text-h1-size: 24px;
    --text-h1-lh: 1.3;
    --text-h1-weight: 700;

    --text-body-size: 15px;
    --text-body-lh: 1.65;
    --text-body-weight: 400;

    --text-body-sm-size: 13px;
    --text-body-sm-lh: 1.6;
    --text-body-sm-weight: 400;

    --text-button-size: 14px;
    --text-button-lh: 1;
    --text-button-weight: 700;

    --tracking-button: 0.04em;

    --space-xs: 4px;
    --space-sm: 8px;
    --space-md: 16px;
    --space-lg: 24px;
    --space-xl: 32px;

    --radius-md: 14px;
    --radius-xl: 20px;
    --radius-full: 9999px;

    --shadow-cta: 0 8px 20px rgba(44, 28, 26, 0.14);
    --shadow-modal: 0 12px 32px rgba(44, 28, 26, 0.22);

    --dur-quick: 150ms;
    --dur-standard: 220ms;

    --ease-standard: cubic-bezier(.2, 0, 0, 1);
    --ease-out: cubic-bezier(.33, 1, .68, 1);
}

* {
    box-sizing: border-box;
}

html,
body {
    margin: 0;
    padding: 0;
}

.bl-auth-body {
    min-height: 100vh;
    font-family: var(--font-sans);
    color: var(--text-primary);
    background: linear-gradient(160deg, var(--bg-base), var(--bg-elevated) 58%, var(--bg-surface));
}

.bl-auth-shell {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-lg);
}

.bl-auth-card {
    width: min(100%, 430px);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    background: rgba(245, 237, 226, 0.94);
    box-shadow: var(--shadow-modal);
    padding: var(--space-xl);
}

.bl-auth-mark {
    margin: 0 0 var(--space-md);
    color: var(--text-muted);
    font-size: 11px;
    line-height: 1.5;
    letter-spacing: var(--tracking-button);
    text-transform: uppercase;
}

.bl-auth-title {
    margin: 0 0 var(--space-sm);
    color: var(--text-primary);
    font: var(--text-h1-weight) var(--text-h1-size)/var(--text-h1-lh) var(--font-sans);
}

.bl-auth-subtitle {
    margin: 0 0 var(--space-lg);
    color: var(--text-secondary);
    font: var(--text-body-sm-weight) var(--text-body-sm-size)/var(--text-body-sm-lh) var(--font-sans);
}

.bl-form {
    display: grid;
    gap: var(--space-md);
}

.bl-field {
    display: grid;
    gap: var(--space-sm);
}

.bl-field-label {
    color: var(--text-secondary);
    font: var(--text-body-sm-weight) var(--text-body-sm-size)/var(--text-body-sm-lh) var(--font-sans);
}

.bl-field-input {
    width: 100%;
    min-height: 46px;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--bg-base);
    color: var(--text-primary);
    font: var(--text-body-weight) var(--text-body-size)/var(--text-body-lh) var(--font-sans);
    padding: 0 14px;
    transition:
        border-color var(--dur-standard) var(--ease-standard),
        box-shadow var(--dur-standard) var(--ease-standard),
        background-color var(--dur-standard) var(--ease-standard);
}

.bl-field-input:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: none;
    background: var(--bg-elevated);
}

.bl-field-input[readonly] {
    color: var(--text-muted);
    background: var(--bg-surface);
}

.bl-field-error {
    color: var(--error);
    font: var(--text-body-sm-weight) var(--text-body-sm-size)/var(--text-body-sm-lh) var(--font-sans);
}

.bl-alert {
    border-radius: var(--radius-md);
    border: 1px solid var(--error);
    background: var(--bg-surface);
    color: var(--error);
    padding: 12px 14px;
    font: var(--text-body-sm-weight) var(--text-body-sm-size)/var(--text-body-sm-lh) var(--font-sans);
}

.bl-btn {
    width: 100%;
    min-height: 46px;
    border-radius: var(--radius-full);
    border: 1px solid transparent;
    font: var(--text-button-weight) var(--text-button-size)/var(--text-button-lh) var(--font-sans);
    letter-spacing: var(--tracking-button);
    cursor: pointer;
    transition:
        transform var(--dur-quick) var(--ease-out),
        filter var(--dur-quick) var(--ease-out),
        background-color var(--dur-standard) var(--ease-standard);
}

.bl-btn:hover {
    filter: brightness(1.03);
}

.bl-btn:active {
    transform: translateY(1px);
}

.bl-btn-primary {
    background: var(--primary);
    color: var(--on-primary);
    box-shadow: var(--shadow-cta);
}

.bl-btn-secondary {
    background: var(--bg-surface);
    color: var(--text-primary);
    border-color: var(--border);
}

.bl-auth-divider {
    margin: var(--space-lg) 0;
    border: 0;
    border-top: 1px solid var(--border);
}

.bl-auth-link-row {
    margin: var(--space-lg) 0 0;
    color: var(--text-secondary);
    font: var(--text-body-sm-weight) var(--text-body-sm-size)/var(--text-body-sm-lh) var(--font-sans);
}

.bl-link {
    color: var(--primary);
    text-decoration: none;
    font-weight: 700;
}

.bl-link:hover {
    text-decoration: underline;
}

.bl-actions {
    display: grid;
    gap: var(--space-sm);
}

.bl-helper-copy {
    margin: 0;
    color: var(--text-secondary);
    font: var(--text-body-weight) var(--text-body-size)/var(--text-body-lh) var(--font-sans);
}

@@media (max-width: 520px) {
    .bl-auth-shell {
        padding: var(--space-md);
    }

    .bl-auth-card {
        padding: var(--space-lg);
    }
}

@@media (prefers-reduced-motion: reduce) {
    .bl-btn,
    .bl-field-input {
        transition-duration: 200ms;
    }
}
</style>
