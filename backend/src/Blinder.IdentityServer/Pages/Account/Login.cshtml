@page
@model Blinder.IdentityServer.Pages.Account.LoginModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Sign in";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Blinder Identity</title>
    <partial name="_AuthPageStyles" />
</head>
<body class="bl-auth-body">
    <main class="bl-auth-shell">
        <section class="bl-auth-card">
            <p class="bl-auth-mark">Blinder Identity</p>
            <h1 class="bl-auth-title">Sign in to Blinder</h1>
            <p class="bl-auth-subtitle">Use your Blinder identity account to continue the authorization flow.</p>

            <form method="post" asp-route-returnUrl="@Model.ReturnUrl" class="bl-form">
                <div asp-validation-summary="ModelOnly" class="bl-alert" role="alert"></div>

                <div class="bl-field">
                    <label asp-for="Input.Email" class="bl-field-label"></label>
                    <input asp-for="Input.Email" class="bl-field-input" autocomplete="email" />
                    <span asp-validation-for="Input.Email" class="bl-field-error"></span>
                </div>

                <div class="bl-field">
                    <label asp-for="Input.Password" class="bl-field-label"></label>
                    <input asp-for="Input.Password" class="bl-field-input" autocomplete="current-password" />
                    <span asp-validation-for="Input.Password" class="bl-field-error"></span>
                </div>

                <button type="submit" class="bl-btn bl-btn-primary">Sign in</button>
            </form>

            @if (Model.ExternalProviders.Any())
            {
                <hr class="bl-auth-divider" />
                <div class="bl-actions">
                    @foreach (var provider in Model.ExternalProviders)
                    {
                        <form method="post"
                              asp-page-handler="ExternalLogin"
                              asp-route-provider="@provider.Name"
                              asp-route-returnUrl="@Model.ReturnUrl">
                            <button type="submit" class="bl-btn bl-btn-secondary">
                                Continue with @provider.DisplayName
                            </button>
                        </form>
                    }
                </div>
            }

            <p class="bl-auth-link-row">
                Don't have an account?
                <a class="bl-link" asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Register</a>
            </p>
        </section>
    </main>
</body>
</html>
