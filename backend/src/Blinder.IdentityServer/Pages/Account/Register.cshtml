@page
@model Blinder.IdentityServer.Pages.Account.RegisterModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Create account";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Blinder Identity</title>
    <partial name="_AuthPageStyles" />
</head>
<body class="bl-auth-body">
    <main class="bl-auth-shell">
        <section class="bl-auth-card">
            <p class="bl-auth-mark">Blinder Identity</p>
            <h1 class="bl-auth-title">Create your Blinder account</h1>
            <p class="bl-auth-subtitle">Register here, then continue straight back into the authorization flow.</p>

            <form method="post" asp-route-returnUrl="@Model.ReturnUrl" class="bl-form">
                <div asp-validation-summary="ModelOnly" class="bl-alert" role="alert"></div>

                <div class="bl-field">
                    <label asp-for="Input.Email" class="bl-field-label"></label>
                    <input asp-for="Input.Email" class="bl-field-input" autocomplete="email" />
                    <span asp-validation-for="Input.Email" class="bl-field-error"></span>
                </div>

                <div class="bl-field">
                    <label asp-for="Input.Password" class="bl-field-label"></label>
                    <input asp-for="Input.Password" class="bl-field-input" autocomplete="new-password" />
                    <span asp-validation-for="Input.Password" class="bl-field-error"></span>
                </div>

                <div class="bl-field">
                    <label asp-for="Input.ConfirmPassword" class="bl-field-label"></label>
                    <input asp-for="Input.ConfirmPassword" class="bl-field-input" autocomplete="new-password" />
                    <span asp-validation-for="Input.ConfirmPassword" class="bl-field-error"></span>
                </div>

                <button type="submit" class="bl-btn bl-btn-primary">Create account</button>
            </form>

            <p class="bl-auth-link-row">
                Already have an account?
                <a class="bl-link" asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Sign in</a>
            </p>
        </section>
    </main>
</body>
</html>